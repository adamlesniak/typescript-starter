{
  "name": "typescript-starter",
  "version": "0.0.1",
  "description": "A minimal repository containing TypeScript, linter and unit tests.",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest",
    "dev": "tsnd ./src/app.ts",
    "test:coverage": "jest --collectCoverage",
    "build": "tsup",
    "lint": "eslint src",
    "prepare": "husky",
    "format": "prettier . --write",
    "lint-staged": "lint-staged",
    "release": "release-please --repo-url=https://github.com/adamlesniak/typescript-starter"
  },
  "lint-staged": {
    "**/*": [
      "npm run lint",
      "npm run format"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/adamlesniak/typescript-starter.git"
  },
  "author": "Adam Lesniakk <hello@alesniak.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/adamlesniak/typescript-starter/issues"
  },
  "homepage": "https://github.com/adamlesniak/typescript-starter#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.43",
    "@types/eslint__js": "^9.14.0",
    "@types/jest": "^30.0.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "release-please": "^17.10.0",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
